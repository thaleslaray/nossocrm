    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst activities = response?.data || [];\n\n// Busca atividade de encerramento pendente\nconst encerramento = activities.find(act => {\n  const title = (act.title || '').toLowerCase();\n  const isEncerramento = title.includes('encerramento') || title.includes('18h');\n  const isPending = !act.completed_at && act.status !== 'completed';\n  return isEncerramento && isPending;\n});\n\nif (!encerramento) {\n  // Se nao encontrou atividade especifica, usa mensagem padrao\n  return [{ json: {\n    found: false,\n    activity_id: null,\n    mensagem: 'Oi! Como nao tivemos retorno, vou finalizar nosso atendimento por aqui. Mas fique tranquilo(a), se precisar de qualquer coisa e so chamar que estaremos a disposicao! Ate mais! 👋'\n  }}];\n}\n\n// Extrai mensagem da descricao\nconst description = encerramento.description || '';\nlet mensagem = '';\n\nconst msgMatch = description.match(/Mensagem de encerramento[:\\s]*([\\s\\S]*?)(?=\\n\\nUltima mensagem|$)/i);\nif (msgMatch && msgMatch[1]) {\n  mensagem = msgMatch[1].trim();\n}\n\nif (!mensagem) {\n  mensagem = 'Oi! Como nao tivemos retorno, vou finalizar nosso atendimento por aqui. Mas fique tranquilo(a), se precisar de qualquer coisa e so chamar que estaremos a disposicao! Ate mais! 👋';\n}\n\nreturn [{ json: {\n  found: true,\n  activity_id: encerramento.id,\n  activity_title: encerramento.title,\n  mensagem\n}}];"
      },
      "id": "extrair-mensagem",
      "name": "Extrair_Mensagem",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1136, 320]
    },
