      "id": "buscar-conversation",
      "name": "Buscar_Conversation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1360, 320],
      "credentials": {
        "httpHeaderAuth": {
          "id": "RhZY4FZWk3Pstr72",
          "name": "Coronel CRM"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst mensagemData = $('Extrair_Mensagem').first().json;\nconst links = response?.data || [];\n\nif (!links.length) {\n  return [{ json: {\n    found: false,\n    error: 'Nenhum conversation link encontrado',\n    mensagem: mensagemData.mensagem,\n    activity_id: mensagemData.activity_id\n  }}];\n}\n\nconst link = links[0];\n\nreturn [{ json: {\n  found: true,\n  conversation_id: link.chatwootConversationId || link.chatwoot_conversation_id,\n  mensagem: mensagemData.mensagem,\n  activity_id: mensagemData.activity_id\n}}];"
      },
