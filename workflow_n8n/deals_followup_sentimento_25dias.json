      "id": "buscar-conversations",
      "name": "Buscar_Conversations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [688, 480],
      "credentials": {
        "httpHeaderAuth": {
          "id": "RhZY4FZWk3Pstr72",
          "name": "Coronel CRM"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const cfg = $('Configuracoes').first().json;\nconst response = $input.first().json;\nconst links = response?.data || [];\n\nconst horasMin = Number(cfg.HorasMinimas || 18);\nconst horasMax = Number(cfg.HorasMaximas || 24);\nconst nowMs = Date.now();\n\nconst output = [];\n\nfor (const link of links) {\n  const dealId = link.dealId || link.deal_id;\n  if (!dealId) continue;\n  \n  // Usar lastMessageAt se existir, senao usar updatedAt como fallback\n  const lastMessageAt = link.lastMessageAt || link.last_message_at || link.updatedAt || link.updated_at;\n  if (!lastMessageAt) continue;\n  \n  const lastMs = Date.parse(lastMessageAt);\n  if (!Number.isFinite(lastMs)) continue;\n  \n  const horasSemInteracao = (nowMs - lastMs) / (1000 * 60 * 60);\n  \n  // Filtrar: >= 18h sem interacao (inclui > 24h para mover direto para Finalizado)\n  if (horasSemInteracao < horasMin) continue;\n  \n  // Identificar a fonte da data usada\n  const dataSource = (link.lastMessageAt || link.last_message_at) ? 'lastMessageAt' : 'updatedAt';\n  \n  // Determinar acao: dentro da janela (18-24h) ou fora (>24h)\n  const dentroJanela24h = horasSemInteracao <= horasMax;\n  \n  output.push({\n    json: {\n      dealId,\n      conversationId: link.chatwootConversationId || link.chatwoot_conversation_id,\n      contactId: link.contactId || link.contact_id,\n      lastMessageAt,\n      dataSource,\n      lastMessagePreview: link.lastMessagePreview || link.last_message_preview || '',\n      lastMessageSender: link.lastMessageSender || link.last_message_sender || '',\n      horasSemInteracao: Math.round(horasSemInteracao * 10) / 10,\n      dentroJanela24h,\n      status: link.status\n    }\n  });\n}\n\nreturn output.length > 0 ? output : [{ json: { _empty: true, count: 0 } }];"
      },
