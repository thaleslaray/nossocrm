    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const cfg = $('Configuracoes').first().json;\nconst candidatos = $('Filtrar_Candidatos_18h').all();\nconst stagesData = $input.item.json;\n\n// Buscar o deal correspondente do nó Buscar_Deal usando $itemIndex\nconst allDeals = $('Buscar_Deal').all();\nconst dealData = allDeals[$itemIndex]?.json || {};\nconst deal = dealData?.data || dealData || {};\nconst stages = stagesData?.data || [];\n\nconst normalize = (s) => String(s || '').normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').toLowerCase().trim();\n\n// Encontrar stage atual\nconst currentStage = stages.find(s => s.id === deal.stage_id);\nconst currentStageLabel = normalize(currentStage?.label || '');\n\n// Ignorar se ja esta em Finalizado ou Follow-up\nconst isFinalizadoOrFollowup = \n  currentStageLabel.includes('finaliz') ||\n  currentStageLabel.includes('follow');\n\nif (isFinalizadoOrFollowup) {\n  return { json: { _skip: true, reason: 'Deal ja em Finalizado ou Follow-up', dealId: deal.id, stage: currentStage?.label } };\n}\n\n// Encontrar candidato correspondente\nconst candidato = candidatos.find(c => c.json.dealId === deal.id)?.json || {};\n\n// Determinar se deve enviar mensagem (dentro da janela 24h)\nconst dentroJanela24h = candidato.dentroJanela24h !== false;\nconst enviarMensagem = dentroJanela24h;\n\nreturn {\n  json: {\n    dealId: deal.id,\n    dealTitle: deal.title,\n    boardId: deal.board_id,\n    currentStageId: deal.stage_id,\n    currentStageLabel: currentStage?.label || '',\n    conversationId: candidato.conversationId,\n    contactId: candidato.contactId || deal.contact_id,\n    horasSemInteracao: candidato.horasSemInteracao,\n    lastMessagePreview: candidato.lastMessagePreview,\n    aiSummary: deal.ai_summary || '',\n    mensagemEncerramento: cfg.MensagemEncerramento,\n    targetStage: cfg.StageFinalizado,\n    enviarMensagem,\n    dentroJanela24h\n  }\n};"
      },
